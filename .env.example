# AWS
AWS_REGION=us-east-1

# DynamoDB
DYNAMODB_TABLE=cloud-audit

# S3
S3_BUCKET_REPORTS=cloud-audit-reports

# SNS / messaging (if used later)
SNS_TOPIC_ARN=

# AI layer (Bedrock / OpenAI) — real keys live in AWS Secrets Manager / SSM,
# never here. This stays a placeholder so the variable name is documented.
AI_PROVIDER_API_KEY=
AI_MOCK_RESPONSES=true
